# Remote Dev Configuration
# Copy to .env and customize

# Where project volumes are stored on the host
RDEV_DATA_DIR=./data/projects

# Docker image to use for project containers
RDEV_IMAGE=rdev-base:latest

# Host mode: "local" for direct docker, or "user@host" for SSH
RDEV_HOST=local

# Docker binary (override if needed)
RDEV_DOCKER=docker
